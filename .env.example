# LiteLLM / 各模型 API Key
# 只需填写你使用的模型对应的 Key

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# Ollama（本地模型，无需 Key）
# OLLAMA_BASE_URL=http://localhost:11434

# LiteLLM 统一设置（如用 LiteLLM 代理）
# LITELLM_API_KEY=
# LITELLM_API_BASE=

# 日志级别（DEBUG / INFO / WARNING / ERROR）
LOG_LEVEL=INFO
